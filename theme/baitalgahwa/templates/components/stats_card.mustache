{{!
    @template theme_baitalgahwa/components/stats_card
    Context: label, value (inside #stats block)
}}
<div class="baitalgahwa-stat card h-100 border-0 shadow-sm">
    <div class="card-body">
        <div class="baitalgahwa-stat__value h2 mb-1">{{ value }}</div>
        <div class="baitalgahwa-stat__label text-muted small">{{ label }}</div>
    </div>
</div>
